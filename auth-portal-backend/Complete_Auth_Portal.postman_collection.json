{
  "info": {
    "name": "Complete Authentication Portal",
    "description": "Full test suite: Auth, Profile, Uploads, and RBAC (Roles/Permissions) modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "moderatorToken", "value": "" },
    { "key": "resetToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "roleId", "value": "" },
    { "key": "permissionId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"03001234567\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/verify-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"newPassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Profile (self)",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            }
          }
        },
        {
          "name": "Update My Profile - Empty Body (negative)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/me",
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Get Profile - No Token (negative)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "3. File Upload",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Admin - User Management",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/auth/users"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/auth/users/{{userId}}"
          }
        },
        {
          "name": "Update User By Id (name/phone only)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/users/{{userId}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Edited By Admin\"\n}" }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/auth/users/{{userId}}"
          }
        },
        {
          "name": "Delete Self (negative)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/auth/users/REPLACE_WITH_OWN_ID"
          }
        }
      ]
    },
    {
      "name": "5. Admin - Roles CRUD",
      "item": [
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/roles",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"auditor\",\n  \"description\": \"Read-only compliance role\"\n}" }
          }
        },
        {
          "name": "List All Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/roles"
          }
        },
        {
          "name": "Get Role By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/roles/{{roleId}}"
          }
        },
        {
          "name": "Update Role Details",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/roles/{{roleId}}",
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/roles/{{roleId}}"
          }
        },
        {
          "name": "Delete Core Role (negative)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/roles/REPLACE_WITH_MODERATOR_ROLE_ID"
          }
        }
      ]
    },
    {
      "name": "6. Admin - Permissions CRUD",
      "item": [
        {
          "name": "Create Permission",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/permissions",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"export_reports\",\n  \"description\": \"Can export system reports\"\n}" }
          }
        },
        {
          "name": "List All Permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/permissions"
          }
        },
        {
          "name": "Get Permission By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/permissions/{{permissionId}}"
          }
        },
        {
          "name": "Update Permission",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/permissions/{{permissionId}}",
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Delete Permission",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/permissions/{{permissionId}}"
          }
        }
      ]
    },
    {
      "name": "7. Admin - Role<->Permission Linking",
      "item": [
        {
          "name": "Assign Permission To Role",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/roles/permissions",
            "body": { "mode": "raw", "raw": "{\n  \"roleId\": {{roleId}},\n  \"permissionId\": {{permissionId}}\n}" }
          }
        },
        {
          "name": "Remove Permission From Role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/roles/{{roleId}}/permissions/{{permissionId}}"
          }
        }
      ]
    },
    {
      "name": "8. Admin - User<->Role Linking",
      "item": [
        {
          "name": "Assign Role To User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/users/roles",
            "body": { "mode": "raw", "raw": "{\n  \"userId\": {{userId}},\n  \"roleId\": {{roleId}}\n}" }
          }
        },
        {
          "name": "Remove Role From User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}/roles/{{roleId}}"
          }
        },
        {
          "name": "Update User Role (legacy column)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/users/{{userId}}/role",
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"moderator\"\n}" }
          }
        }
      ]
    },
    {
      "name": "9. Admin - User Role-Scoped Permission Overrides",
      "item": [
        {
          "name": "Grant Override Permission",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/users/roles/permissions",
            "body": { "mode": "raw", "raw": "{\n  \"userId\": {{userId}},\n  \"roleId\": {{roleId}},\n  \"permissionId\": {{permissionId}}\n}" }
          }
        },
        {
          "name": "View User Role-Scoped Overrides",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}/roles/{{roleId}}/permissions"
          }
        },
        {
          "name": "Revoke Override Permission",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}/roles/{{roleId}}/permissions/{{permissionId}}"
          }
        }
      ]
    },
    {
      "name": "10. Access Control Negative Tests",
      "item": [
        {
          "name": "List Users as Moderator (expect 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{moderatorToken}}" }],
            "url": "{{baseUrl}}/auth/users"
          }
        },
        {
          "name": "Get User By Id as Moderator (expect 200)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{moderatorToken}}" }],
            "url": "{{baseUrl}}/auth/users/{{userId}}"
          }
        },
        {
          "name": "Admin Routes as Moderator (expect 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{moderatorToken}}" }],
            "url": "{{baseUrl}}/admin/roles"
          }
        },
        {
          "name": "Get User By Id as Plain User (expect 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/users/{{userId}}"
          }
        }
      ]
    }
  ]
}
